datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SYSTEM_ADMIN
  TENANT_ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum ClassRole {
  TEACHER
  STUDENT
}

model Tenant {
  id          String       @id @default(uuid())
  name        String
  code        String       @unique // e.g. "shibuya-juku"
  plan        String       @default("STANDARD")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  classes     Class[]
  assignments Assignment[]

  @@index([code])
}

model User {
  id               String                      @id @default(uuid())
  tenantId         String                      @default("default-b2c")
  tenant           Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email            String
  password         String
  nickname         String
  role             Role                        @default(STUDENT)
  schoolYear       Int                         @default(1) // Grade 1, 2, 3
  currentXp        Int                         @default(0)
  level            Int                         @default(1)
  streakCount      Int                         @default(0)
  lastActiveDate   DateTime?
  parentalConsent  Boolean                     @default(false)
  aiHintCountToday Int                         @default(0)
  lastAiHintDate   String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  attempts         Attempt[]
  badges           UserBadge[]
  parentMessages   ParentMessage[]
  classes          ClassEnrollment[]
  
  // As student: progresses for homework assignments
  assignmentProgresses StudentAssignmentProgress[]
  
  // As parent: parent relations (Parent-Child)
  parentRelations  ParentChildRelation[]       @relation("ChildToParent")
  childRelations   ParentChildRelation[]       @relation("ParentToChild")

  // Phase-12
  sentStamps          PeerStamp[]              @relation("SentStamps")
  receivedStamps      PeerStamp[]              @relation("ReceivedStamps")
  hiramekiTips        HiramekiTip[]
  childCelebrations   ParentalCelebration[]    @relation("ChildCelebrations")

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Class {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  grade       Int               // Grade year
  enrollments ClassEnrollment[]
  assignments Assignment[]

  // Phase-12
  hiramekiTips  HiramekiTip[]
  classMissions ClassMission[]

  @@index([tenantId])
}

model ClassEnrollment {
  id        String    @id @default(uuid())
  classId   String
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ClassRole @default(STUDENT)

  @@unique([classId, userId])
}

model ParentChildRelation {
  id        String @id @default(uuid())
  parentId  String
  parent    User   @relation("ParentToChild", fields: [parentId], references: [id], onDelete: Cascade)
  childId   String
  child     User   @relation("ChildToParent", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
}

model Assignment {
  id          String                      @id @default(uuid())
  tenantId    String
  tenant      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId     String
  class       Class                       @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  lessonId    String                      // Targets a curriculum Lesson ID
  dueDate     DateTime
  createdAt   DateTime                    @default(now())
  progresses  StudentAssignmentProgress[]

  @@index([tenantId])
  @@index([classId])
}

model StudentAssignmentProgress {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  isCompleted  Boolean    @default(false)
  completedAt  DateTime?

  @@unique([assignmentId, studentId])
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique // e.g. "math", "english"
  grade     Int      @default(1) // Grade 1, 2, 3
  isEnabled Boolean  @default(true)
  units     Unit[]
}

model Unit {
  id          String   @id @default(uuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  name        String
  order       Int
  description String
  isLocked    Boolean  @default(false)
  lessons     Lesson[]
}

model Lesson {
  id        String     @id @default(uuid())
  unitId    String
  unit      Unit       @relation(fields: [unitId], references: [id])
  name      String
  order     Int
  questions Question[]
}

enum QuestionType {
  MULTIPLE_CHOICE
  NUMBER_INPUT
  FILL_IN_BLANK
  SINGLE_CHOICE
  NUMERIC
  TEXT_SHORT
  FILL_BLANK
}

model Question {
  id          String       @id @default(uuid())
  lessonId    String
  lesson      Lesson       @relation(fields: [lessonId], references: [id])
  type        QuestionType
  prompt      String
  answers     String[]     // Accepted correct answers
  options     String[]     // For multiple choice
  explanation String
  hints       String[]     // Fallback static hints
  attempts    Attempt[]
  isDynamic   Boolean      @default(false)
}

model Attempt {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  questionId      String
  question        Question @relation(fields: [questionId], references: [id])
  isCorrect       Boolean
  hintsUsed       Int      @default(0)
  answerSubmitted String
  durationSeconds Int?     // Time in seconds to complete the question
  createdAt       DateTime @default(now())
  errorType       String?
  aiDiagnosis     String?

  // Phase-12
  parentalCelebrations ParentalCelebration[]
}

model Badge {
  id            String      @id @default(uuid())
  name          String
  iconUrl       String
  conditionType String      // e.g. "STREAK", "XP", "CORRECT_ANSWERS"
  threshold     Int
  users         UserBadge[]
}

model UserBadge {
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@id([userId, badgeId])
}

model ParentMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PeerStamp {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SentStamps", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedStamps", fields: [receiverId], references: [id], onDelete: Cascade)
  stampType  String   // e.g. "DONT_GIVE_UP", "NICE_GRIT", "SHINING"
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
}

model HiramekiTip {
  id        String   @id @default(uuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nickname  String   // "がんばるオニオン" などの自動割当される匿名ニックネーム
  content   String
  isSafe    Boolean  @default(true) // AI Safety Filter 検知結果
  createdAt DateTime @default(now())

  @@index([classId])
  @@index([userId])
}

model ClassMission {
  id             String   @id @default(uuid())
  classId        String
  class          Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title          String   // ミッションのタイトル（例：「今週のあきらめない勉強時間」）
  targetMinutes  Int      // 目標時間（分）
  currentMinutes Int      @default(0) // 現在の累計時間（分）
  dueDate        DateTime
  createdAt      DateTime @default(now())

  @@index([classId])
}

model ParentalCelebration {
  id            String   @id @default(uuid())
  childId       String
  child         User     @relation("ChildCelebrations", fields: [childId], references: [id], onDelete: Cascade)
  attemptId     String
  attempt       Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  token         String   @unique // 保護者用リンクのトークン
  parentStamp   String?  // 保護者からのスタンプ ("GREAT_JOB", "PROUD_OF_YOU", "KEEP_IT_UP" など)
  parentComment String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([childId])
}
