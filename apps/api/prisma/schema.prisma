datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SYSTEM_ADMIN
  TENANT_ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum ClassRole {
  TEACHER
  STUDENT
}

model Tenant {
  id          String       @id @default(uuid())
  name        String
  code        String       @unique // e.g. "shibuya-juku"
  plan        String       @default("STANDARD")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  classes     Class[]
  assignments Assignment[]

  @@index([code])
}

model User {
  id               String                      @id @default(uuid())
  tenantId         String                      @default("default-b2c")
  tenant           Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email            String
  password         String
  nickname         String
  role             Role                        @default(STUDENT)
  schoolYear       Int                         @default(1) // Grade 1, 2, 3
  currentXp        Int                         @default(0)
  level            Int                         @default(1)
  streakCount      Int                         @default(0)
  lastActiveDate   DateTime?
  parentalConsent  Boolean                     @default(false)
  aiHintCountToday Int                         @default(0)
  lastAiHintDate   String?
  abuseCount       Int                         @default(0)
  abuseLastAt      DateTime?
  lockedUntil      DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  attempts         Attempt[]
  badges           UserBadge[]
  parentMessages   ParentMessage[]
  classes          ClassEnrollment[]
  
  // As student: progresses for homework assignments
  assignmentProgresses StudentAssignmentProgress[]
  
  // As parent: parent relations (Parent-Child)
  parentRelations  ParentChildRelation[]       @relation("ChildToParent")
  childRelations   ParentChildRelation[]       @relation("ParentToChild")

  // Phase-12
  sentStamps          PeerStamp[]              @relation("SentStamps")
  receivedStamps      PeerStamp[]              @relation("ReceivedStamps")
  hiramekiTips        HiramekiTip[]
  childCelebrations   ParentalCelebration[]    @relation("ChildCelebrations")

  // Phase-15.5
  childSafetyAlerts   SafetyAlert[]            @relation("ChildSafetyAlerts")

  // Phase-16-A
  bossBattleParticipants BossBattleParticipant[]
  bossApprovalAudits     BossApprovalAudit[]

  // Phase-16-B
  avatars                Avatar[]
  avatarQuotas           AvatarGenerationQuota[]

  // Phase-16-C
  speechAnalyticsConsent Boolean               @default(false)
  speechAnalysisEnabled  Boolean               @default(true)
  microphoneConsent      MicrophoneConsent?
  speechDailyQuotas      SpeechDailyQuota[]
  phonemeStruggles       PhonemeStruggle[]
  speechAnalyses         SpeechAnalysis[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Class {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  grade       Int               // Grade year
  enrollments ClassEnrollment[]
  assignments Assignment[]

  // Phase-12
  hiramekiTips  HiramekiTip[]
  classMissions ClassMission[]

  // Phase-16-A
  bossBattles      BossBattle[]
  bossQuestionPool BossQuestionPool?

  @@index([tenantId])
}

model ClassEnrollment {
  id        String    @id @default(uuid())
  classId   String
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ClassRole @default(STUDENT)

  @@unique([classId, userId])
}

model ParentChildRelation {
  id        String @id @default(uuid())
  parentId  String
  parent    User   @relation("ParentToChild", fields: [parentId], references: [id], onDelete: Cascade)
  childId   String
  child     User   @relation("ChildToParent", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
}

model Assignment {
  id          String                      @id @default(uuid())
  tenantId    String
  tenant      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId     String
  class       Class                       @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  lessonId    String                      // Targets a curriculum Lesson ID
  dueDate     DateTime
  createdAt   DateTime                    @default(now())
  progresses  StudentAssignmentProgress[]

  @@index([tenantId])
  @@index([classId])
}

model StudentAssignmentProgress {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  isCompleted  Boolean    @default(false)
  completedAt  DateTime?

  @@unique([assignmentId, studentId])
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique // e.g. "math", "english"
  grade     Int      @default(1) // Grade 1, 2, 3
  isEnabled Boolean  @default(true)
  units     Unit[]
}

model Unit {
  id          String   @id @default(uuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  name        String
  order       Int
  description String
  isLocked    Boolean  @default(false)
  lessons     Lesson[]
}

model Lesson {
  id        String     @id @default(uuid())
  unitId    String
  unit      Unit       @relation(fields: [unitId], references: [id])
  name      String
  order     Int
  questions Question[]
}

enum QuestionType {
  MULTIPLE_CHOICE
  NUMBER_INPUT
  FILL_IN_BLANK
  SINGLE_CHOICE
  NUMERIC
  TEXT_SHORT
  FILL_BLANK
}

model Question {
  id          String       @id @default(uuid())
  lessonId    String
  lesson      Lesson       @relation(fields: [lessonId], references: [id])
  type        QuestionType
  prompt      String
  answers     String[]     // Accepted correct answers
  options     String[]     // For multiple choice
  explanation String
  hints       String[]     // Fallback static hints
  attempts    Attempt[]
  isDynamic   Boolean      @default(false)
}

model Attempt {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId      String
  question        Question @relation(fields: [questionId], references: [id])
  isCorrect       Boolean
  hintsUsed       Int      @default(0)
  answerSubmitted String
  durationSeconds Int?     // Time in seconds to complete the question
  createdAt       DateTime @default(now())
  errorType       String?
  aiDiagnosis     String?

  // Phase-12
  parentalCelebrations ParentalCelebration[]
}

model Badge {
  id            String      @id @default(uuid())
  name          String
  iconUrl       String
  conditionType String      // e.g. "STREAK", "XP", "CORRECT_ANSWERS"
  threshold     Int
  users         UserBadge[]
}

model UserBadge {
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@id([userId, badgeId])
}

model ParentMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PeerStamp {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SentStamps", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedStamps", fields: [receiverId], references: [id], onDelete: Cascade)
  stampType  String   // e.g. "DONT_GIVE_UP", "NICE_GRIT", "SHINING"
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
}

model HiramekiTip {
  id        String   @id @default(uuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nickname  String   // "がんばるオニオン" などの自動割当される匿名ニックネーム
  content   String
  isSafe    Boolean  @default(true) // AI Safety Filter 検知結果
  createdAt DateTime @default(now())

  @@index([classId])
  @@index([userId])
}

model ClassMission {
  id             String   @id @default(uuid())
  classId        String
  class          Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title          String   // ミッションのタイトル（例：「今週のあきらめない勉強時間」）
  targetMinutes  Int      // 目標時間（分）
  currentMinutes Int      @default(0) // 現在の累計時間（分）
  dueDate        DateTime
  createdAt      DateTime @default(now())

  @@index([classId])
}

model ParentalCelebration {
  id            String   @id @default(uuid())
  childId       String
  child         User     @relation("ChildCelebrations", fields: [childId], references: [id], onDelete: Cascade)
  attemptId     String
  attempt       Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  token         String   @unique // 保護者用リンクのトークン
  parentStamp   String?  // 保護者からのスタンプ ("GREAT_JOB", "PROUD_OF_YOU", "KEEP_IT_UP" など)
  parentComment String?
  isResponded   Boolean  @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([childId])
}

// Notification queue picked up by an out-of-band worker (email / LINE / push).
// The worker is intentionally out of scope for Phase 15.5 — rows are written
// here so the work can be reliably picked up later without losing alerts.
model SafetyAlert {
  id          String   @id @default(uuid())
  childUserId String
  child       User     @relation("ChildSafetyAlerts", fields: [childUserId], references: [id], onDelete: Cascade)
  alertType   String   // "ABUSE_HARD_LOCK" など
  payload     String   // JSON-stringified context (sourceRoute, lockedUntil, etc.)
  status      String   @default("QUEUED") // QUEUED | SENT | FAILED
  createdAt   DateTime @default(now())
  sentAt      DateTime?

  @@index([childUserId])
  @@index([status])
}

// Phase-16-A: Boss Battle Models
model Boss {
  id            String       @id @default(uuid())
  name          String
  maxHp         Int
  attribute     String       // e.g. "NEGATIVE_NUMBERS", "EQUATIONS"
  durationWeeks Int          @default(1)
  createdAt     DateTime     @default(now())
  battles       BossBattle[]
}

model BossBattle {
  id           String                  @id @default(uuid())
  classId      String
  class        Class                   @relation(fields: [classId], references: [id], onDelete: Cascade)
  bossId       String
  boss         Boss                    @relation(fields: [bossId], references: [id], onDelete: Cascade)
  currentHp    Int
  startsAt     DateTime
  endsAt       DateTime
  defeatedAt   DateTime?
  isAlive      Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  participants BossBattleParticipant[]

  @@index([classId])
  @@index([bossId])
}

model BossBattleParticipant {
  userId            String
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  battleId          String
  battle            BossBattle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  totalDamage       Int        @default(0)
  gritAttemptsCount Int        @default(0)
  celebrationSeenAt DateTime?
  createdAt         DateTime   @default(now())

  @@id([userId, battleId])
}

model BossQuestionPool {
  id              String   @id @default(uuid())
  classId         String   @unique
  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  questionsJson   String   // Cache of generated 100 questions as JSON
  lastGeneratedAt DateTime @default(now())
  createdAt       DateTime @default(now())
}

model BossApprovalAudit {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  action    String   // "APPROVE" | "REPLACE_QUESTION"
  targetId  String   // ID of the approved question pool or battle
  details   String
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
}

model Avatar {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String    // PENDING | APPROVED | REJECTED
  baseVegetable   String
  mainColor       String
  facialFeatures  String
  clothing        String
  expression      String
  prompt          String
  objectKey       String    @unique
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  approvalAudits  AvatarApprovalAudit[]

  @@index([userId])
}

model AvatarGenerationQuota {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekBucket String   // e.g. "2026-W21"
  count      Int      @default(0)
  resetAt    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, weekBucket])
  @@index([userId])
}

model AvatarApprovalAudit {
  id            String   @id @default(uuid())
  // Nullable + onDelete: SetNull lets the audit trail survive avatar deletion.
  // The cron-cleanup flow records an audit and then deletes the avatar;
  // if this cascaded the audit would be erased in the same request,
  // defeating the audit purpose. With SetNull the audit stays,
  // avatarId becomes null, but moderator action / hash / reason remain
  // queryable for compliance review.
  avatarId      String?
  avatar        Avatar?  @relation(fields: [avatarId], references: [id], onDelete: SetNull)
  moderatorId   String   // Teacher or Parent User ID
  action        String   // "APPROVE" | "REJECT"
  imageHash     String   // Integrational verification hash
  reason        String?  // Rejection reason (preset choices)
  createdAt     DateTime @default(now())

  @@index([avatarId])
  @@index([moderatorId])
}

model MicrophoneConsent {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentedAt    DateTime @default(now())
  consentVersion String
  userAgent      String
  ipHash         String
  createdAt      DateTime @default(now())
}

model SpeechDailyQuota {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayBucket  String   // e.g. "2026-05-24"
  count      Int      @default(0)
  resetAt    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, dayBucket])
  @@index([userId])
}

model PhonemeStruggle {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneme       String   // e.g. "r", "l", "th", "ae"
  struggleCount Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([userId, phoneme])
  @@index([userId])
}

model SpeechAnalysis {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId       String?
  audioDeletedAt DateTime? // Deletion audit trail
  createdAt      DateTime  @default(now())

  @@index([userId])
}


