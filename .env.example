# Database connection URL for PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rakkyo?schema=public"

# API Port
PORT=4000

# NextAuth/JWT Secret (for signing tokens)
NEXTAUTH_SECRET="some-very-secret-key-at-least-32-chars-long"

# AI Provider Configurations
GEMINI_API_KEY=""
CLAUDE_API_KEY=""

# HMAC secret for app-served avatar signed URLs (>= 32 chars in production)
AVATAR_STORAGE_SECRET=""

# Avatar object storage backend (issue #8): memory | fs | gcs
#  - memory : in-process, NOT durable; dev/test only (forbidden in production)
#  - fs     : filesystem volume; set RAKKYO_STORAGE_DIR (required in production)
#  - gcs    : Google Cloud Storage; set RAKKYO_GCS_BUCKET (+ GOOGLE_APPLICATION_CREDENTIALS)
#             and `pnpm add @google-cloud/storage` in apps/api
# Production fails fast if this is unset or set to "memory".
RAKKYO_STORAGE_BACKEND="memory"
RAKKYO_STORAGE_DIR=""
RAKKYO_GCS_BUCKET=""
